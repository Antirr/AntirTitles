// Admin title editor — form for creating a new runtime title.
// Bind #CreateButton  with EventData(Action="submit", @Id, @DisplayName, ...) capturing all text fields.
// Bind #AddPassiveEffectBtn / #AddActiveEffectBtn / #AddRequirementBtn with form capture + EffectTarget.
// Populate #RarityInput.Entries from Java with the five rarity IDs.
// Populate #PassiveEffectList / #ActiveEffectList / #RequirementList from Java (AdminPendingRow entries).

$C = "../../Common.ui";

$C.@PageOverlay {

  $C.@DecoratedContainer {
    Anchor: (Width: 660, Height: 640);

    #Title {
      $C.@Title {
        @Text = "NEW TITLE";
      }
    }

    #Content {
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Full: 28);

      Label #EditorError {
        Style: (FontSize: 12, TextColor: #c85050, Wrap: true);
        Anchor: (Bottom: 10);
        Visible: false;
      }

      // ── ID ───────────────────────────────────────────────────────────────
      Label {
        Text: "Title ID";
        Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1);
        Anchor: (Height: 18, Bottom: 4);
      }
      $C.@TextField #IdInput {
        Anchor: (Height: 34, Bottom: 14);
        PlaceholderText: "e.g. WolfMaster";
      }

      // ── Display name ─────────────────────────────────────────────────────
      Label {
        Text: "Display Name";
        Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1);
        Anchor: (Height: 18, Bottom: 4);
      }
      $C.@TextField #DisplayNameInput {
        Anchor: (Height: 34, Bottom: 14);
        PlaceholderText: "e.g. Wolf Master";
      }

      // ── Description ──────────────────────────────────────────────────────
      Label {
        Text: "Description";
        Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1);
        Anchor: (Height: 18, Bottom: 4);
      }
      $C.@TextField #DescriptionInput {
        Anchor: (Height: 34, Bottom: 14);
        PlaceholderText: "Awarded to those who have mastered the wolf.";
      }

      // ── Rarity (dropdown) ────────────────────────────────────────────────
      Label {
        Text: "Rarity";
        Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1);
        Anchor: (Height: 18, Bottom: 4);
      }
      $C.@DropdownBox #RarityInput {
        Anchor: (Height: 34, Bottom: 14);
      }

      // ── Tags ─────────────────────────────────────────────────────────────
      Label {
        Text: "Tags  (comma-separated)";
        Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1);
        Anchor: (Height: 18, Bottom: 4);
      }
      $C.@TextField #TagsInput {
        Anchor: (Height: 34, Bottom: 14);
        PlaceholderText: "e.g. Wolf,Combat";
      }

      // ── UI Accent color ───────────────────────────────────────────────────
      Label {
        Text: "UI Accent Color  (optional hex, overrides rarity)";
        Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1);
        Anchor: (Height: 18, Bottom: 4);
      }
      $C.@TextField #AccentColorInput {
        Anchor: (Height: 34, Bottom: 20);
        PlaceholderText: "#bb8a2c";
      }

      // ── Passive effects ───────────────────────────────────────────────────
      Group { Anchor: (Height: 1, Bottom: 16); Background: (Color: #1e2d40); }

      Group {
        LayoutMode: Left;
        Anchor: (Height: 30, Bottom: 6);
        Label {
          Text: "PASSIVE EFFECTS";
          Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
          FlexWeight: 1;
        }
        Button #AddPassiveEffectBtn {
          Anchor: (Width: 80, Height: 28);
          Style: (Default: (Background: #1a2d3a), Hovered: (Background: #223848));
          Label {
            Text: "+ ADD";
            Style: (FontSize: 9, RenderBold: true, TextColor: #5a90b0, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Full: 0);
          }
        }
      }
      Group #PassiveEffectList {
        LayoutMode: Top;
        Anchor: (Bottom: 16);
      }

      // ── Active effects ────────────────────────────────────────────────────
      Group {
        LayoutMode: Left;
        Anchor: (Height: 30, Bottom: 6);
        Label {
          Text: "ACTIVE EFFECTS";
          Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
          FlexWeight: 1;
        }
        Button #AddActiveEffectBtn {
          Anchor: (Width: 80, Height: 28);
          Style: (Default: (Background: #1a2d3a), Hovered: (Background: #223848));
          Label {
            Text: "+ ADD";
            Style: (FontSize: 9, RenderBold: true, TextColor: #5a90b0, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Full: 0);
          }
        }
      }
      Group #ActiveEffectList {
        LayoutMode: Top;
        Anchor: (Bottom: 16);
      }

      // ── Requirements ──────────────────────────────────────────────────────
      Group {
        LayoutMode: Left;
        Anchor: (Height: 30, Bottom: 6);
        Label {
          Text: "REQUIREMENTS";
          Style: (FontSize: 11, TextColor: #7a9ab0, RenderUppercase: true, LetterSpacing: 1, VerticalAlignment: Center);
          FlexWeight: 1;
        }
        Button #AddRequirementBtn {
          Anchor: (Width: 80, Height: 28);
          Style: (Default: (Background: #1a2d3a), Hovered: (Background: #223848));
          Label {
            Text: "+ ADD";
            Style: (FontSize: 9, RenderBold: true, TextColor: #5a90b0, HorizontalAlignment: Center, VerticalAlignment: Center);
            Anchor: (Full: 0);
          }
        }
      }
      Group #RequirementList {
        LayoutMode: Top;
        Anchor: (Bottom: 24);
      }

      // ── Actions ───────────────────────────────────────────────────────────
      Group { Anchor: (Height: 1, Bottom: 20); Background: (Color: #1e2d40); }

      Group #EditorActions {
        LayoutMode: Left;
        Anchor: (Height: 44);

        $C.@TextButton #CreateButton {
          @Text = "CREATE";
          Anchor: (Width: 150, Height: 44);
        }

        Group { Anchor: (Width: 12); }

        $C.@CancelTextButton #CancelButton {
          @Text = "CANCEL";
          Anchor: (Width: 120, Height: 44);
        }
      }
    }
  }
}

$C.@BackButton {}
